<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:startmodels="using:AkkornStudio.UI.Services.Start.Models"
             xmlns:start="using:AkkornStudio.UI.Controls.Start"
             xmlns:shell="using:AkkornStudio.UI.Controls.Shell"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.Start.StartMenuControl"
             x:DataType="vm:StartMenuViewModel"
             x:Name="Root">

  <UserControl.Styles>
    <Style Selector="TextBlock.kicker">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="LetterSpacing" Value="0.6"/>
    </Style>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightTitle}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightTitle}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightTitle}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.nav.active">
      <Setter Property="FontWeight" Value="{StaticResource FontWeightTitle}"/>
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>
    <Style Selector="Button.tips-pill">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightStrong}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingCard}"/>
      <Setter Property="BoxShadow" Value="{StaticResource PanelShadow}"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.card:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="Border.card.hero-card">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0.0" Color="{StaticResource AccentPrimary}"/>
          <GradientStop Offset="1.0" Color="{StaticResource Bg1}"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource BtnPrimaryBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource BtnPrimaryFgBrush}"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingPrimaryButton}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightAction}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="{StaticResource BtnGhostBgBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource BtnGhostFgBrush}"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="Padding" Value="{StaticResource StartPaddingGhostButton}"/>
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.template-tile">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusMD}"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>
    <Style Selector="Button.template-tile:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="StackPanel.empty-state TextBlock">
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.quick-action-card">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0.0" Color="{StaticResource AccentSecondary}"/>
          <GradientStop Offset="1.0" Color="{StaticResource Bg2}"/>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
    <Style Selector="Border.empty-placeholder">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderActiveBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <!-- Primary action tiles in the hero -->
    <Style Selector="Button.action-tile">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusMD}"/>
      <Setter Property="Padding" Value="14,14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="RenderTransform" Value="translateY(0px)"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14"/>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.action-tile:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="translateY(-3px)"/>
    </Style>
    <Style Selector="Button.action-tile.primary-tile">
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.action-tile TextBlock.tile-title">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
      <Setter Property="FontWeight" Value="{StaticResource FontWeightAction}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.action-tile TextBlock.tile-sub">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Colored icon chip for each action -->
    <Style Selector="Border.icon-chip">
      <Setter Property="Width" Value="38"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Accent bar before a section title -->
    <Style Selector="Border.section-bar">
      <Setter Property="Width" Value="3"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Kicker rendered as a subtle pill badge -->
    <Style Selector="Border.kicker-badge">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}"/>
      <Setter Property="Padding" Value="9,3"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Decorative node-graph motif (echoes the canvas/node identity) -->
    <Style Selector="Border.motif-node">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
    </Style>

    <!-- Clickable saved-connection rows -->
    <Style Selector="Button.connection-row">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.connection-row:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
    </Style>

    <!-- Responsive typography scale for desktop ranges -->
    <Style Selector="UserControl.start-compact TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>
    <Style Selector="UserControl.start-compact TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>
    <Style Selector="UserControl.start-compact Button.primary">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>
    <Style Selector="UserControl.start-compact Button.ghost">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>

    <Style Selector="UserControl.start-large TextBlock.brand">
      <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.h1">
      <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.h2">
      <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.nav">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.meta">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-large TextBlock.version">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-large Button.primary">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
    <Style Selector="UserControl.start-large Button.ghost">
      <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Background="{StaticResource Bg0Brush}">
    <Canvas Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.22">
      <!-- Glow azul (acento primário) — canto superior esquerdo -->
      <Border Width="420" Height="420" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource AccentPrimaryBrush}" Canvas.Left="-160" Canvas.Top="-240"/>
      <!-- Verde — lateral direita central (existente) -->
      <Border Width="360" Height="360" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource Bg2Brush}" Canvas.Right="-90" Canvas.Top="110"/>

      <!-- Glow violeta (acento secundário) — canto superior direito -->
      <Border Width="300" Height="300" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource AccentSecondaryBrush}" Canvas.Right="-110" Canvas.Top="-110"/>
      <!-- Ciano — centro-esquerda (análogo ao azul, transição entre hero e recentes) -->
      <Border Width="260" Height="260" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource Bg1Brush}" Canvas.Left="300" Canvas.Top="250"/>
      <!-- Teal — inferior esquerdo (análogo ao verde, seção Recentes) -->
      <Border Width="340" Height="340" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource Bg2Brush}" Canvas.Left="-80" Canvas.Top="460"/>
      <!-- Âmbar — inferior direito (complementar ao azul, seção Templates) -->
      <Border Width="280" Height="280" CornerRadius="{StaticResource RadiusPill}" Background="{StaticResource BtnWarningBgBrush}" Canvas.Right="-70" Canvas.Top="520"/>
    </Canvas>

    <shell:AppHeaderBar Grid.Row="0"
                        Title="{Binding [main.brand], Source={x:Static loc:LocalizationService.Instance}}"
                        ShowBrandBadge="True"
                        ShowWindowControls="True">
      <shell:AppHeaderBar.RightContent>
        <StackPanel Orientation="Horizontal" Spacing="{StaticResource StartSpaceSM}" VerticalAlignment="Center">
          <Button Classes="tips-pill" Content="{Binding [start.tips], Source={x:Static loc:LocalizationService.Instance}}">
            <ToolTip.Tip>
              <StackPanel Spacing="4" MaxWidth="320">
                <TextBlock Text="{Binding [start.tips.quick], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="{StaticResource FontWeightStrong}"/>
                <TextBlock Text="{Binding [start.tips.item1], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding [start.tips.item2], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding [start.tips.item3], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding [start.tips.shortcut], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
              </StackPanel>
            </ToolTip.Tip>
          </Button>
          <Button Classes="icon-ghost"
                  ToolTip.Tip="{Binding [menu.settings], Source={x:Static loc:LocalizationService.Instance}}"
                  VerticalAlignment="Center"
                  Command="{Binding OpenSettingsCommand}">
            <mi:MaterialIcon Kind="CogOutline" Width="14" Height="14"/>
          </Button>
        </StackPanel>
      </shell:AppHeaderBar.RightContent>
    </shell:AppHeaderBar>

    <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Grid Margin="24" ColumnDefinitions="2.2*,18,1*" RowDefinitions="Auto,Auto,Auto" MinHeight="640">

      <!-- HERO: workspace intro + primary actions -->
      <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Classes="card hero-card" Name="HeroBlock" ClipToBounds="True">
        <Grid RowDefinitions="Auto,Auto">
          <!-- Decorative node-graph motif (top-right, non-interactive) -->
          <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False" Opacity="0.5" HorizontalAlignment="Right" Width="240" Height="150" ClipToBounds="True">
            <Path Stroke="{StaticResource AccentPrimaryBrush}" StrokeThickness="1.5" Data="M 64,30 C 100,30 96,18 132,18"/>
            <Path Stroke="{StaticResource AccentSecondaryBrush}" StrokeThickness="1.5" Data="M 64,38 C 104,38 92,104 130,104"/>
            <Path Stroke="{StaticResource StatusOkBrush}" StrokeThickness="1.5" Data="M 196,34 C 220,34 210,96 196,96"/>
            <Border Classes="motif-node" Canvas.Left="8" Canvas.Top="20" Width="56" Height="30">
              <Border Height="3" VerticalAlignment="Top" Margin="0" CornerRadius="4,4,0,0" Background="{StaticResource AccentPrimaryBrush}"/>
            </Border>
            <Border Classes="motif-node" Canvas.Left="132" Canvas.Top="4" Width="64" Height="34" BorderBrush="{StaticResource AccentSecondaryBrush}">
              <Border Height="3" VerticalAlignment="Top" CornerRadius="4,4,0,0" Background="{StaticResource AccentSecondaryBrush}"/>
            </Border>
            <Border Classes="motif-node" Canvas.Left="130" Canvas.Top="88" Width="64" Height="34" BorderBrush="{StaticResource StatusOkBrush}">
              <Border Height="3" VerticalAlignment="Top" CornerRadius="4,4,0,0" Background="{StaticResource StatusOkBrush}"/>
            </Border>
            <Ellipse Canvas.Left="60" Canvas.Top="26" Width="7" Height="7" Fill="{StaticResource AccentPrimaryBrush}"/>
            <Ellipse Canvas.Left="129" Canvas.Top="15" Width="7" Height="7" Fill="{StaticResource AccentSecondaryBrush}"/>
            <Ellipse Canvas.Left="127" Canvas.Top="101" Width="7" Height="7" Fill="{StaticResource StatusOkBrush}"/>
          </Canvas>

          <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,14">
            <Border Classes="kicker-badge">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="{StaticResource AccentPrimaryBrush}"/>
                <TextBlock Classes="kicker" Text="{Binding [start.workspace], Source={x:Static loc:LocalizationService.Instance}}"/>
              </StackPanel>
            </Border>
            <TextBlock Classes="h1" Text="{Binding [start.resumeTitle], Source={x:Static loc:LocalizationService.Instance}}"/>
            <TextBlock Classes="meta" Text="{Binding [start.resumeSubtitle], Source={x:Static loc:LocalizationService.Instance}}" MaxWidth="560" HorizontalAlignment="Left"/>
          </StackPanel>

          <Grid Grid.Row="1" ColumnDefinitions="*,10,*,10,*,10,*,10,*">
            <Button Grid.Column="0" Classes="action-tile primary-tile" Command="{Binding CreateNewDiagramCommand}">
              <StackPanel Spacing="10">
                <Border Classes="icon-chip" Background="{StaticResource BtnInfoBgBrush}">
                  <mi:MaterialIcon Kind="Sitemap" Width="20" Height="20" Foreground="{StaticResource AccentPrimaryBrush}"/>
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Classes="tile-title" Text="{Binding [menu.newDiagram], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                  <TextBlock Classes="tile-sub" Text="Monte SQL por nós" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Classes="action-tile" Command="{Binding OpenSqlEditorCommand}">
              <StackPanel Spacing="10">
                <Border Classes="icon-chip" Background="{StaticResource BtnSuccessBgBrush}">
                  <mi:MaterialIcon Kind="ConsoleLine" Width="20" Height="20" Foreground="{StaticResource StatusOkBrush}"/>
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Classes="tile-title" Text="Editor SQL" TextWrapping="Wrap"/>
                  <TextBlock Classes="tile-sub" Text="Escreva e rode queries" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Grid.Column="4" Classes="action-tile" Command="{Binding OpenSchemaCompareCommand}">
              <StackPanel Spacing="10">
                <Border Classes="icon-chip" Background="#2A2150">
                  <mi:MaterialIcon Kind="TableSync" Width="20" Height="20" Foreground="{StaticResource AccentSecondaryBrush}"/>
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Classes="tile-title" Text="{Binding [start.compareTables], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                  <TextBlock Classes="tile-sub" Text="Diff de schema/banco" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Grid.Column="6" Classes="action-tile" Command="{Binding OpenStructureAnalysisCommand}">
              <StackPanel Spacing="10">
                <Border Classes="icon-chip" Background="{StaticResource BtnWarningBgBrush}">
                  <mi:MaterialIcon Kind="Stethoscope" Width="20" Height="20" Foreground="{StaticResource StatusWarningBrush}"/>
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Classes="tile-title" Text="Diagnóstico" TextWrapping="Wrap"/>
                  <TextBlock Classes="tile-sub" Text="Análise de estrutura" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Grid.Column="8" Classes="action-tile" Command="{Binding OpenFromDiskCommand}">
              <StackPanel Spacing="10">
                <Border Classes="icon-chip" Background="{StaticResource Bg2Brush}">
                  <mi:MaterialIcon Kind="FolderOpenOutline" Width="20" Height="20" Foreground="{StaticResource StatusInfoBrush}"/>
                </Border>
                <StackPanel Spacing="2">
                  <TextBlock Classes="tile-title" Text="{Binding [main.open], Source={x:Static loc:LocalizationService.Instance}}" TextWrapping="Wrap"/>
                  <TextBlock Classes="tile-sub" Text="Abrir do disco" TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </Button>
          </Grid>
        </Grid>
      </Border>

      <!-- RECENTS (left) -->
      <Border Grid.Row="1" Grid.Column="0" Margin="0,18,0,0" Classes="card" Name="RecentSection" MinHeight="300">
        <Grid RowDefinitions="Auto,Auto,*">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Classes="section-bar"/>
            <TextBlock Classes="h2" Text="{Binding [start.recentProjectsTitle], Source={x:Static loc:LocalizationService.Instance}}"/>
          </StackPanel>

          <TextBox Grid.Row="1"
                   Classes="field"
                   Margin="{StaticResource StartMarginInnerTop}"
                   Text="{Binding RecentSearchQuery}"
                   Watermark="{Binding [start.searchRecent], Source={x:Static loc:LocalizationService.Instance}}"
                   Height="34"/>

          <ScrollViewer Grid.Row="2" Margin="{StaticResource StartMarginInnerTop}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" IsVisible="{Binding HasRecentProjects}">
            <ItemsControl ItemsSource="{Binding RecentProjects}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="startmodels:StartRecentProjectItem">
                  <Button Classes="ghost"
                          Width="220"
                          Height="160"
                          Margin="0,0,10,0"
                          Padding="{StaticResource StartPaddingGhostButton}"
                          Tag="{Binding}"
                          Click="RecentProjectCard_Click"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch">
                    <start:RecentProjectCard/>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="2" Classes="empty-placeholder" VerticalAlignment="Center" IsVisible="{Binding HasRecentProjects, Converter={x:Static BoolConverters.Not}}">
            <StackPanel Classes="empty-state" Spacing="8">
              <TextBlock Text="{Binding [start.noRecentTitle], Source={x:Static loc:LocalizationService.Instance}}" Classes="h2" FontSize="{StaticResource FontSizeHeading}"/>
              <TextBlock Text="{Binding [start.noRecentSubtitle], Source={x:Static loc:LocalizationService.Instance}}" Classes="meta" Opacity="0.9"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- SAVED CONNECTIONS (right) -->
      <Border Grid.Row="1" Grid.Column="2" Margin="0,18,0,0" Classes="card" Name="ConnectionsSection" MinHeight="300">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Classes="section-bar" Background="{StaticResource AccentSecondaryBrush}"/>
            <TextBlock Classes="h2" Text="{Binding [start.savedConnectionsTitle], Source={x:Static loc:LocalizationService.Instance}}"/>
            <Border Classes="chip"><TextBlock Classes="meta" Text="{Binding [start.chip.connections], Source={x:Static loc:LocalizationService.Instance}}"/></Border>
          </StackPanel>

          <TextBlock Grid.Row="1"
                     Margin="{StaticResource StartMarginInnerTop}"
                     Classes="meta"
                     Opacity="0.9"
                     TextWrapping="Wrap"
                     Text="{Binding [start.savedConnectionsSubtitle], Source={x:Static loc:LocalizationService.Instance}}"/>

          <ScrollViewer Grid.Row="2" Margin="{StaticResource StartMarginInnerTop}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSavedConnections}">
            <ItemsControl ItemsSource="{Binding SavedConnections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="startmodels:StartSavedConnectionItem">
                  <Button Classes="connection-row"
                          Tag="{Binding}"
                          Click="SavedConnectionCard_Click">
                    <start:ConnectionStatusCard/>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="2" Classes="empty-placeholder" VerticalAlignment="Center" Margin="0,10,0,0" IsVisible="{Binding HasSavedConnections, Converter={x:Static BoolConverters.Not}}">
            <StackPanel Classes="empty-state" Spacing="8">
              <TextBlock Text="{Binding [start.noConnectionsTitle], Source={x:Static loc:LocalizationService.Instance}}" Classes="h2" FontSize="{StaticResource FontSizeHeading}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding [start.noConnectionsSubtitle], Source={x:Static loc:LocalizationService.Instance}}" Classes="meta" Opacity="0.9" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Button Grid.Row="3"
                  Classes="primary"
                  Margin="0,12,0,0"
                  HorizontalAlignment="Stretch"
                  Content="{Binding [start.newConnection], Source={x:Static loc:LocalizationService.Instance}}"
                  Command="{Binding OpenConnectionsCommand}"/>
        </Grid>
      </Border>

      <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Classes="card" Margin="0,18,0,0" Name="TemplatesSection">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Classes="section-bar" Background="{StaticResource StatusOkBrush}"/>
            <TextBlock Classes="h2" Text="{Binding [start.exploreTemplates], Source={x:Static loc:LocalizationService.Instance}}"/>
            <Border Classes="chip"><TextBlock Classes="meta" Text="{Binding [start.templatesFavoritesHint], Source={x:Static loc:LocalizationService.Instance}}"/></Border>
          </StackPanel>
          <ScrollViewer Grid.Row="1" Margin="{StaticResource StartMarginInnerTop}" Padding="2,0,2,8" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Height="176" MinHeight="176">
            <ItemsControl ItemsSource="{Binding TemplateCatalog}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="startmodels:StartTemplateItem">
                  <Grid Margin="6,6,6,6" Width="236" Height="152">
                    <Button Classes="template-tile"
                            Width="236"
                            Height="152"
                            Padding="{StaticResource StartPaddingGhostButton}"
                            Tag="{Binding}"
                            Click="TemplateCard_Click"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                      <start:TemplateCard/>
                    </Button>

                    <Button Classes="icon-ghost"
                            Width="24"
                            Height="24"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,8,8,0"
                            Tag="{Binding}"
                            Click="TemplateFavorite_Click"
                            ToolTip.Tip="{Binding [start.favoriteTemplate], Source={x:Static loc:LocalizationService.Instance}}"
                            ZIndex="2">
                      <Grid>
                        <TextBlock Text="★" Foreground="{StaticResource BtnWarningFgBrush}" IsVisible="{Binding IsFavorite}"/>
                        <TextBlock Text="☆" Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding !IsFavorite}"/>
                      </Grid>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
      </Grid>
    </ScrollViewer>

  </Grid>
</UserControl>
