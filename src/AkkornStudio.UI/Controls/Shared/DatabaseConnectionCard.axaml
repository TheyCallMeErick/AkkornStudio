<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.Shared.DatabaseConnectionCard"
             x:CompileBindings="False"
             x:Name="Root">

  <Border Background="{StaticResource Bg2Brush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusLG}"
          Padding="12">

    <StackPanel Spacing="10">

      <!-- Row 1: icon + status + latency + disconnect -->
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Border Grid.Column="0"
                Width="36"
                Height="36"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSM}"
                VerticalAlignment="Center">
          <mi:MaterialIcon Kind="Database"
                           Width="16"
                           Height="16"
                           Foreground="{StaticResource AccentPrimaryHoverBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
          <StackPanel Orientation="Horizontal" Spacing="5"
                      IsVisible="{Binding IsConnected, ElementName=Root}">
            <Ellipse x:Name="ConnectedStatusDot"
                     Width="6"
                     Height="6"
                     Fill="{StaticResource StatusOkBrush}"
                     RenderTransformOrigin="0.5,0.5"/>
            <TextBlock Text="Conectado"
                       Foreground="{StaticResource StatusOkBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="{StaticResource FontWeightHeading}"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="5"
                      IsVisible="{Binding IsReloading, ElementName=Root}">
            <Ellipse Width="6" Height="6" Fill="{StaticResource StatusWarningBrush}"/>
            <TextBlock Text="Carregando schema..."
                       Foreground="{StaticResource StatusWarningBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       FontWeight="{StaticResource FontWeightHeading}"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     IsVisible="{Binding LatencyMs, ElementName=Root, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Run Text="Latencia: "/>
            <Run Text="{Binding LatencyMs, ElementName=Root}"/>
            <Run Text=" ms"/>
          </TextBlock>
          <TextBlock Text="{Binding ConnectionName, ElementName=Root}"
                     FontSize="{StaticResource FontSizeCaption}"
                     FontWeight="{StaticResource FontWeightHeading}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     IsVisible="{Binding ConnectionName, ElementName=Root, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="1"/>
          <TextBlock Text="{Binding ConnectionSubtitle, ElementName=Root}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     IsVisible="{Binding ConnectionSubtitle, ElementName=Root, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="1"/>
        </StackPanel>

        <Button x:Name="DisconnectButton"
                Grid.Column="2"
                Classes="secondary"
                Padding="7,3"
                CornerRadius="{StaticResource RadiusSM}"
                FontSize="{StaticResource FontSizeCaption}"
                Command="{Binding DisconnectCommand, ElementName=Root}"
                IsVisible="{Binding IsConnected, ElementName=Root}"
                Content="Desconectar"/>
      </Grid>

      <Border Height="1" Background="{StaticResource BorderSubtleBrush}"/>

      <!-- Row 2: connection selector trigger -->
      <StackPanel Spacing="3">
        <TextBlock Text="Conexao"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border Background="{StaticResource Bg1Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="10,7">
            <TextBlock Text="{Binding ConnectionName, ElementName=Root}"
                       FontSize="{StaticResource FontSizeLabel}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"/>
          </Border>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding OpenConnectionManagerCommand, ElementName=Root}"
                  IsVisible="{Binding ShowConnectionManagerButton, ElementName=Root}"
                  IsEnabled="{Binding IsReloading, ElementName=Root, Converter={x:Static BoolConverters.Not}}"
                  ToolTip.Tip="Abrir conexoes">
            <mi:MaterialIcon Kind="SwapHorizontal" Width="16" Height="16"/>
          </Button>
        </Grid>
      </StackPanel>

      <!-- Row 3: database picker -->
      <StackPanel Spacing="3"
                  IsVisible="{Binding IsDatabaseSelectionVisible, ElementName=Root}">
        <TextBlock Text="Database/Catalog"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border Background="{StaticResource Bg1Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="10,7">
            <TextBlock Text="{Binding SelectedDatabase, ElementName=Root}"
                       FontSize="{StaticResource FontSizeLabel}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"/>
          </Border>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  IsEnabled="{Binding IsReloading, ElementName=Root, Converter={x:Static BoolConverters.Not}}"
                  Click="OnOpenDatabaseSwitcherClick"
                  ToolTip.Tip="Selecionar banco">
            <mi:MaterialIcon Kind="SwapHorizontal" Width="16" Height="16"/>
          </Button>
        </Grid>
      </StackPanel>

      <!-- Row 4: schema picker -->
      <StackPanel Spacing="3">
        <TextBlock Text="Schema"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border Background="{StaticResource Bg1Brush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="10,7">
            <TextBlock Text="{Binding SelectedSchema, ElementName=Root}"
                       FontSize="{StaticResource FontSizeLabel}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"/>
          </Border>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  IsEnabled="{Binding IsReloading, ElementName=Root, Converter={x:Static BoolConverters.Not}}"
                  ToolTip.Tip="Selecionar schema">
            <mi:MaterialIcon Kind="ChevronDown" Width="16" Height="16"/>
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <Border Background="{StaticResource Bg1Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSM}"
                        Padding="6"
                        MinWidth="220">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Schemas disponiveis"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ListBox ItemsSource="{Binding AvailableSchemas, ElementName=Root}"
                             SelectedItem="{Binding SelectedSchema, ElementName=Root, Mode=OneWay}"
                             SelectionChanged="OnSchemaSelectionChanged"
                             MaxHeight="220">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*">
                            <mi:MaterialIcon Kind="TableColumn" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Text="{Binding .}"
                                       TextTrimming="CharacterEllipsis"/>
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>
              </Flyout>
            </Button.Flyout>
          </Button>
        </Grid>
      </StackPanel>

      <!-- Row 5: metadata summary + progress bar -->
      <Border Background="{StaticResource Bg0Brush}"
              CornerRadius="{StaticResource RadiusSM}"
              Padding="9,7">
        <StackPanel Spacing="5">
          <TextBlock x:Name="MetadataSummaryText"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource AccentSecondaryHoverBrush}"
                     Text="{Binding MetadataSummary, ElementName=Root}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding MetadataSummary, ElementName=Root, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <TextBlock x:Name="VersionText"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     Text="{Binding MetadataDetails, ElementName=Root}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding MetadataDetails, ElementName=Root, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <TextBlock Text="Versao indisponivel"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     IsVisible="{Binding MetadataDetails, ElementName=Root, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
          <TextBlock Text="Metadados indisponiveis"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="{StaticResource FontSizeCaption}"
                     Foreground="{StaticResource TextMutedBrush}"
                     IsVisible="{Binding MetadataSummary, ElementName=Root, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
          <ProgressBar x:Name="ReloadingProgressBar"
                       IsIndeterminate="True"
                       Height="2"
                       Foreground="{StaticResource AccentPrimaryBrush}"
                       Background="{StaticResource BorderSubtleBrush}"
                       IsVisible="{Binding IsReloading, ElementName=Root}"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </Border>
</UserControl>
