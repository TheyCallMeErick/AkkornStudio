<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:connmodels="using:AkkornStudio.UI.Services.ConnectionManager.Models"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.ConnectionManagerControl"
             x:Name="RootConnectionManager"
             x:DataType="vm:ConnectionManagerViewModel">

  <UserControl.Styles>
    <Style Selector="Border.connection-picker-card">
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusLG}"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="MinHeight" Value="124"/>
    </Style>

    <Style Selector="Border.connection-picker-card:pointerover">
      <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryHoverBrush}"/>
      <Setter Property="BoxShadow" Value="0 10 20 0 #22000000"/>
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style Selector="Button.connection-card-action">
      <Setter Property="MinWidth" Value="36"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.connection-card-action.connect">
      <Setter Property="Background" Value="#1A2563EB"/>
      <Setter Property="BorderBrush" Value="#4A60A5FA"/>
      <Setter Property="Foreground" Value="#60A5FA"/>
    </Style>

    <Style Selector="Button.connection-card-action.edit">
      <Setter Property="Background" Value="#1A92400E"/>
      <Setter Property="BorderBrush" Value="#4AF59E0B"/>
      <Setter Property="Foreground" Value="#F59E0B"/>
    </Style>

    <Style Selector="Button.connection-card-action.delete">
      <Setter Property="Background" Value="#1A991B1B"/>
      <Setter Property="BorderBrush" Value="#4AEF4444"/>
      <Setter Property="Foreground" Value="#EF4444"/>
    </Style>

    <Style Selector="Border.connection-provider-pill">
      <Setter Property="Background" Value="#162B3242"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style Selector="Border.connection-meta-pill">
      <Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource RadiusSM}"/>
      <Setter Property="Padding" Value="6,3"/>
    </Style>

    <Style Selector="Border.wizard-provider-card">
      <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
    </Style>

    <Style Selector="Border.wizard-provider-card.wizard-selected">
      <Setter Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="Background" Value="{StaticResource PanelActiveBrush}"/>
      <Setter Property="BoxShadow" Value="0 0 0 1 #204A90E2, 0 8 20 0 #1A4A90E2"/>
    </Style>
  </UserControl.Styles>

  <Border Width="860" MaxHeight="620" Classes="surface-floating">
    <Grid RowDefinitions="Auto,*">
      <Border Grid.Row="0" Classes="surface-floating-header" Padding="20,14">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Border Width="30" Height="30" CornerRadius="{StaticResource RadiusSM}"
                    Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderFocusBrush}" BorderThickness="1">
              <mi:MaterialIcon Kind="DatabaseSettings" Width="16" Height="16" Foreground="{StaticResource AccentPrimaryBrush}"/>
            </Border>
            <StackPanel Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding [connection.title], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightTitle}" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding [connection.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                         FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>

          <Button Grid.Column="2" Classes="icon-ghost" Command="{Binding CloseCommand}"
                  ToolTip.Tip="{Binding [tooltip.closeEsc], Source={x:Static loc:LocalizationService.Instance}}">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid IsVisible="{Binding IsConnectionPickerMode}" RowDefinitions="Auto,Auto,Auto,*" Margin="16">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <StackPanel Spacing="2">
              <TextBlock Text="Conexoes" FontSize="{StaticResource FontSizeTitle}" FontWeight="{StaticResource FontWeightTitle}"/>
              <TextBlock Text="Selecione uma conexao para conectar, editar ou excluir." Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Classes="primary" Command="{Binding OpenCreateConnectionFormCommand}" VerticalAlignment="Top">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                <TextBlock Text="Nova conexao"/>
              </StackPanel>
            </Button>
          </Grid>

          <Border Grid.Row="1"
                  IsVisible="{Binding TestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Background="{StaticResource Bg0Brush}"
                  BorderBrush="{Binding TestStatusColor}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource RadiusSM}"
                  Padding="10,8"
                  Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <mi:MaterialIcon Kind="InformationOutline" Width="14" Height="14" Foreground="{Binding TestStatusColor}"/>
              <TextBlock Text="{Binding TestStatus}"
                         FontSize="{StaticResource FontSizeCaption}"
                         Foreground="{Binding TestStatusColor}"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Classes="surface-card" Padding="10" Margin="0,0,0,10">
            <DockPanel>
              <mi:MaterialIcon DockPanel.Dock="Left"
                               Kind="Magnify"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Width="15"
                               Height="15"
                               VerticalAlignment="Center"
                               Margin="0,0,7,0"/>
              <TextBox Classes="field"
                       Text="{Binding ConnectionPickerSearchQuery}"
                       Watermark="Buscar conexao, banco ou provedor..."
                       Background="Transparent"
                       BorderBrush="Transparent"
                       BorderThickness="0"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Padding="0"
                       FontSize="{StaticResource FontSizeCaption}"/>
            </DockPanel>
          </Border>

          <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="10">
              <ItemsControl ItemsSource="{Binding FilteredConnectionCards}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="connection-picker-card" Margin="0,0,0,10" HorizontalAlignment="Stretch">
                      <Grid RowDefinitions="Auto,Auto"
                            ColumnDefinitions="Auto,*,Auto"
                            RowSpacing="8"
                            ColumnSpacing="12">
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Grid.RowSpan="2"
                                Width="36"
                                Height="36"
                                Background="{StaticResource Bg0Brush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSM}"
                                VerticalAlignment="Center">
                          <Grid>
                            <mi:MaterialIcon Kind="Database"
                                              Width="18"
                                              Height="18"
                                              Foreground="{StaticResource AccentPrimaryHoverBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <Image Source="{Binding ProviderIconSvgSource}"
                                   Width="28"
                                   Height="28"
                                   Stretch="Uniform"/>
                          </Grid>
                        </Border>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="2,0,0,0" Spacing="4" VerticalAlignment="Center">
                          <TextBlock Text="{Binding ConnectionName}"
                                     FontWeight="{StaticResource FontWeightStrong}"
                                     FontSize="{StaticResource FontSizeBody}"
                                     TextTrimming="CharacterEllipsis"/>
                          <Border Classes="connection-provider-pill"
                                  HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ProviderName}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"/>
                          </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="0"
                                    Grid.Column="2"
                                    Grid.RowSpan="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                          <Button Classes="connection-card-action delete"
                                  Command="{Binding DataContext.DeleteConnectionProfileCommand, ElementName=RootConnectionManager}"
                                  CommandParameter="{Binding Profile}"
                                  ToolTip.Tip="Excluir conexao">
                            <mi:MaterialIcon Kind="Delete" Width="15" Height="15"/>
                          </Button>
                          <Button Classes="connection-card-action edit"
                                  Command="{Binding DataContext.EditConnectionProfileCommand, ElementName=RootConnectionManager}"
                                  CommandParameter="{Binding Profile}"
                                  ToolTip.Tip="Editar conexao">
                            <mi:MaterialIcon Kind="Pencil" Width="15" Height="15"/>
                          </Button>
                          <Button Classes="connection-card-action connect"
                                  Command="{Binding DataContext.ConnectWithProfileCommand, ElementName=RootConnectionManager}"
                                  CommandParameter="{Binding Profile}"
                                  ToolTip.Tip="Conectar">
                            <mi:MaterialIcon Kind="LanConnect" Width="15" Height="15"/>
                          </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="2,0,0,0"
                                    Orientation="Horizontal"
                                    Spacing="6">
                          <Border Classes="connection-meta-pill">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                              <mi:MaterialIcon Kind="DatabaseOutline" Width="12" Height="12" Foreground="{StaticResource TextMutedBrush}"/>
                              <TextBlock Text="{Binding DatabaseName}"
                                         FontSize="{StaticResource FontSizeCaption}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         MaxWidth="210"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                          </Border>
                          <Border Classes="connection-meta-pill">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                              <mi:MaterialIcon Kind="Server" Width="12" Height="12" Foreground="{StaticResource TextMutedBrush}"/>
                              <TextBlock Text="{Binding HostName}"
                                         FontSize="{StaticResource FontSizeCaption}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         MaxWidth="180"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Classes="surface-card" Padding="14" IsVisible="{Binding ShowConnectionPickerNoProfilesState}">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                  <TextBlock Text="Nenhuma conexao cadastrada." Foreground="{StaticResource TextSecondaryBrush}"/>
                  <Button Classes="primary compact" Command="{Binding OpenCreateConnectionFormCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <mi:MaterialIcon Kind="Plus" Width="14" Height="14"/>
                      <TextBlock Text="Criar conexao"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Border>

              <Border Classes="surface-card" Padding="14" IsVisible="{Binding ShowConnectionPickerNoResultsState}">
                <TextBlock Text="Nenhuma conexao encontrada para a busca atual."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>

        <Grid IsVisible="{Binding IsConnectionFormMode}" RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Border Padding="20,16">
              <StackPanel Spacing="0">
                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,10">
                  <Button Grid.Column="0" Classes="secondary compact" Command="{Binding BackToConnectionPickerCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <mi:MaterialIcon Kind="ArrowLeft" Width="13" Height="13"/>
                      <TextBlock Text="Voltar"/>
                    </StackPanel>
                  </Button>
                  <TextBlock Grid.Column="1" Text="Formulario de conexao" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>

                <StackPanel IsVisible="{Binding IsEditing}" Spacing="0">
                  <Border Classes="surface-card"
                          IsVisible="{Binding IsNewProfileFlow}"
                          Padding="12,10"
                          Margin="0,0,0,12">
                    <Grid ColumnDefinitions="*,Auto,*">
                      <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding [connection.wizard.step.provider], Source={x:Static loc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="{StaticResource FontWeightTitle}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding [connection.wizard.step.provider.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="->" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                      <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding [connection.wizard.step.form], Source={x:Static loc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="{StaticResource FontWeightTitle}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding [connection.wizard.step.form.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                      </StackPanel>
                    </Grid>
                  </Border>

                  <StackPanel IsVisible="{Binding IsProviderSelectionStepVisible}" Spacing="12">
                    <TextBlock Text="{Binding [connection.wizard.title], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeTitle}"
                               FontWeight="{StaticResource FontWeightTitle}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding [connection.wizard.subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <ItemsControl ItemsSource="{x:Static vm:ConnectionManagerViewModel.AvailableProviderOptions}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" ItemWidth="150" ItemHeight="130"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Margin="0,0,12,12"
                                  Classes="secondary"
                                  Command="{ReflectionBinding DataContext.SelectProviderForNewProfileCommand, ElementName=RootConnectionManager}"
                                  CommandParameter="{Binding .}">
                            <Border Classes="surface-card wizard-provider-card"
                                    Classes.wizard-selected="{Binding IsSelectedWizard}"
                                    Padding="12" MinWidth="138" MinHeight="112">
                              <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{Binding SvgImageSource}" Width="42" Height="42" Stretch="Uniform"/>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="{StaticResource FontWeightTitle}"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                              </StackPanel>
                            </Border>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel IsVisible="{Binding IsConnectionFormStepVisible}" Spacing="0">
                    <Border Classes="surface-card"
                            IsVisible="{Binding IsProviderSummaryVisible}"
                            Padding="12,10"
                            Margin="0,0,0,12">
                      <Grid ColumnDefinitions="Auto,12,*,Auto">
                        <Image Grid.Column="0"
                               Source="{Binding SelectedProviderOption.SvgImageSource}"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"/>
                        <StackPanel Grid.Column="2" Spacing="2">
                          <TextBlock Text="{Binding [connection.wizard.selectedProvider], Source={x:Static loc:LocalizationService.Instance}}"
                                     FontSize="{StaticResource FontSizeCaption}"
                                     Foreground="{StaticResource TextMutedBrush}"/>
                          <TextBlock Text="{Binding SelectedProviderOption.DisplayName}"
                                     FontSize="{StaticResource FontSizeBody}"
                                     FontWeight="{StaticResource FontWeightTitle}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="3"
                                Classes="secondary compact"
                                Command="{Binding BackToProviderSelectionCommand}">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="ArrowLeft" Width="13" Height="13"/>
                            <TextBlock Text="{Binding [connection.wizard.changeProvider], Source={x:Static loc:LocalizationService.Instance}}"/>
                          </StackPanel>
                        </Button>
                      </Grid>
                    </Border>

                    <TextBlock Classes="label" Text="{Binding [connection.name], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <TextBox Classes="field" Text="{Binding EditName}" Margin="0,0,0,12"
                             Watermark="{Binding [connection.watermark.name], Source={x:Static loc:LocalizationService.Instance}}"/>

                    <TextBlock Classes="label" Text="{Binding [connection.url], Source={x:Static loc:LocalizationService.Instance}}"
                               IsVisible="{Binding !IsSqliteProvider}"/>
                    <Grid ColumnDefinitions="*,8,Auto" Margin="0,0,0,12" IsVisible="{Binding !IsSqliteProvider}">
                      <TextBox Grid.Column="0" Classes="field" Text="{Binding EditConnectionUrl}"
                               Watermark="{Binding [connection.watermark.url], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <Button Grid.Column="2" Classes="secondary" Command="{Binding ImportFromUrlCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <mi:MaterialIcon Kind="Link" Width="13" Height="13"/>
                          <TextBlock Text="{Binding [connection.url.import], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}"/>
                        </StackPanel>
                      </Button>
                    </Grid>

                    <CheckBox IsVisible="{Binding SupportsIntegratedSecurity}"
                              IsChecked="{Binding EditUseIntegratedSecurity}"
                              Margin="0,0,0,10"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Content="{Binding [connection.integratedSecurity], Source={x:Static loc:LocalizationService.Instance}}"/>

                    <Grid IsVisible="{Binding !IsSqliteProvider}" ColumnDefinitions="*,12,100" Margin="0,0,0,12">
                      <StackPanel Grid.Column="0">
                        <TextBlock Classes="label" Text="{Binding [connection.host], Source={x:Static loc:LocalizationService.Instance}}"/>
                        <TextBox Classes="field" Text="{Binding EditHost}" Watermark="{Binding [connection.watermark.host], Source={x:Static loc:LocalizationService.Instance}}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Classes="label" Text="{Binding [connection.port], Source={x:Static loc:LocalizationService.Instance}}"/>
                        <TextBox Classes="field" Text="{Binding EditPort}" Watermark="{Binding [connection.watermark.port], Source={x:Static loc:LocalizationService.Instance}}"/>
                      </StackPanel>
                    </Grid>

                    <TextBlock Classes="label" Text="{Binding [connection.database], Source={x:Static loc:LocalizationService.Instance}}"
                               IsVisible="{Binding !IsSqliteProvider}"/>
                    <TextBlock Classes="label" Text="{Binding [connection.sqlitePath], Source={x:Static loc:LocalizationService.Instance}}"
                               IsVisible="{Binding IsSqliteProvider}"/>
                    <TextBox Classes="field" Text="{Binding EditDatabase}" Margin="0,0,0,12"
                             Watermark="{Binding [connection.watermark.database], Source={x:Static loc:LocalizationService.Instance}}"
                             IsVisible="{Binding !IsSqliteProvider}"/>
                    <Grid IsVisible="{Binding IsSqliteProvider}" ColumnDefinitions="*,8,Auto,8,Auto" Margin="0,0,0,12">
                      <TextBox Grid.Column="0" Classes="field" Text="{Binding EditDatabase}"
                               Watermark="{Binding [connection.watermark.sqlitePath], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <Button Grid.Column="2" Classes="secondary" Click="BrowseSqliteFile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <mi:MaterialIcon Kind="FolderOpen" Width="13" Height="13"/>
                          <TextBlock Text="{Binding [connection.sqliteBrowse], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}"/>
                        </StackPanel>
                      </Button>
                      <Button Grid.Column="4" Classes="secondary" Click="CreateSqliteFile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <mi:MaterialIcon Kind="FilePlus" Width="13" Height="13"/>
                          <TextBlock Text="{Binding [connection.sqliteCreate], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}"/>
                        </StackPanel>
                      </Button>
                    </Grid>

                    <Grid IsVisible="{Binding ShowCredentials}" ColumnDefinitions="*,12,*" Margin="0,0,0,12">
                      <StackPanel Grid.Column="0">
                        <TextBlock Classes="label" Text="{Binding [connection.username], Source={x:Static loc:LocalizationService.Instance}}"/>
                        <TextBox Classes="field" Text="{Binding EditUsername}" Watermark="{Binding [connection.watermark.username], Source={x:Static loc:LocalizationService.Instance}}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Classes="label" Text="{Binding [connection.password], Source={x:Static loc:LocalizationService.Instance}}"/>
                        <TextBox Classes="field" Text="{Binding EditPassword}" PasswordChar="*" Watermark="{Binding [connection.watermark.password], Source={x:Static loc:LocalizationService.Instance}}"/>
                      </StackPanel>
                    </Grid>

                    <CheckBox IsVisible="{Binding ShowCredentials}"
                              IsChecked="{Binding EditRememberPassword}"
                              Margin="0,0,0,12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Content="{Binding [connection.rememberPassword], Source={x:Static loc:LocalizationService.Instance}}"/>

                    <StackPanel IsVisible="{Binding SupportsSsl}" Margin="0,0,0,12" Spacing="8">
                      <CheckBox IsChecked="{Binding EditUseSsl}" Foreground="{StaticResource TextSecondaryBrush}"
                                Content="{Binding [connection.ssl], Source={x:Static loc:LocalizationService.Instance}}"/>
                      <CheckBox IsVisible="{Binding SupportsIntegratedSecurity}" IsChecked="{Binding EditTrustServerCertificate}" Foreground="{StaticResource TextSecondaryBrush}"
                                Content="{Binding [connection.trustServerCertificate], Source={x:Static loc:LocalizationService.Instance}}"/>
                    </StackPanel>

                    <TextBlock Classes="label" Text="{Binding [connection.timeout], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <TextBox Classes="field" Text="{Binding EditTimeout}" Margin="0,0,0,16"
                             Watermark="{Binding [connection.watermark.timeout], Source={x:Static loc:LocalizationService.Instance}}"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </ScrollViewer>

          <Border Grid.Row="1"
                  IsVisible="{Binding IsConnectionFormStepVisible}"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="0,1,0,0"
                  Background="{StaticResource Bg1Brush}"
                  Padding="20,12">
            <StackPanel Spacing="10">
              <Border IsVisible="{Binding TestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      Background="{StaticResource Bg0Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSM}" Padding="10,8">
                <TextBlock Text="{Binding TestStatus}" FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{Binding TestStatusColor}" TextWrapping="Wrap"/>
              </Border>

              <Grid ColumnDefinitions="*,Auto,8,Auto">
                <Button Grid.Column="1" Classes="secondary" Command="{Binding TestConnectionCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="LanConnect" Width="13" Height="13" IsVisible="{Binding !IsTesting}"/>
                    <mi:MaterialIcon Kind="Loading" Width="13" Height="13" IsVisible="{Binding IsTesting}"/>
                    <TextBlock Text="{Binding [connection.action.testConnection], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}"/>
                  </StackPanel>
                </Button>

                <Button Grid.Column="3" Classes="primary" Command="{Binding SaveProfileCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="ContentSave" Width="13" Height="13" IsVisible="{Binding !IsSavingProfile}"/>
                    <mi:MaterialIcon Kind="Loading" Width="13" Height="13" IsVisible="{Binding IsSavingProfile}"/>
                    <TextBlock Text="{Binding [connection.action.saveConnection], Source={x:Static loc:LocalizationService.Instance}}" FontSize="{StaticResource FontSizeBody}"/>
                  </StackPanel>
                </Button>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</UserControl>
