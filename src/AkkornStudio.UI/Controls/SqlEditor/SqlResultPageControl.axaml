<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:result="using:AkkornStudio.UI.Services.SqlEditor.Results"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="AkkornStudio.UI.Controls.SqlEditor.SqlResultPageControl"
             x:Name="Root"
             x:DataType="vm:SqlResultPageViewModel">
  <Grid Margin="8"
        RowDefinitions="Auto,Auto,Auto,Auto,*"
        ColumnDefinitions="280,*"
        IsVisible="{Binding HasSession}">
    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Classes="surface-card"
            Padding="10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            ColumnSpacing="8">
        <Button Grid.Column="0"
                Classes="secondary compact"
                Command="{Binding BackToEditorCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="ArrowLeft" Width="14" Height="14"/>
            <TextBlock Text="{Binding [common.back], Source={x:Static loc:LocalizationService.Instance}}"/>
          </StackPanel>
        </Button>

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="{Binding SqlText}"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis"/>

        <Border Grid.Column="2"
                Classes="chip"
                Padding="8,2">
          <TextBlock Text="{Binding StatusText}"/>
        </Border>

        <Border Grid.Column="3"
                Classes="chip"
                Padding="8,2">
          <TextBlock Text="{Binding RowCountText, StringFormat='Rows: {0}'}"/>
        </Border>

        <Border Grid.Column="4"
                Classes="chip"
                Padding="8,2">
          <TextBlock Text="{Binding ColumnCountText, StringFormat='Columns: {0}'}"/>
        </Border>

        <Border Grid.Column="5"
                Classes="chip"
                Padding="8,2">
          <TextBlock Text="{Binding EditabilityStatusText}"/>
        </Border>

        <Border Grid.Column="6"
                Classes="chip"
                Padding="8,2">
          <TextBlock Text="{Binding PendingEditsCount, StringFormat='Pending: {0}'}"/>
        </Border>

        <Button Grid.Column="7"
                Classes="secondary compact"
                Command="{Binding CancelPendingEditsCommand}"
                Content="Discard Pending"/>

        <Button Grid.Column="8"
                Classes="secondary compact"
                Command="{Binding PreparePendingChangesPreviewCommand}"
                Content="Preview Pending"/>

        <Button Grid.Column="9"
                Classes="secondary compact"
                Command="{Binding GeneratePendingSqlCommand}"
                Content="Generate SQL"/>

        <Button Grid.Column="10"
                Classes="secondary compact"
                Command="{Binding CopyGeneratedPendingSqlCommand}"
                Content="Copy SQL"/>

        <Button Grid.Column="11"
                Classes="secondary compact"
                Command="{Binding SendGeneratedPendingSqlToEditorCommand}"
                Content="Send to Editor"/>

        <Button Grid.Column="12"
                Classes="secondary compact"
                Command="{Binding RefreshSessionCommand}"
                Content="Refresh"/>

        <CheckBox Grid.Column="13"
                IsEnabled="{Binding IsTransactionModeAvailable}"
                IsChecked="{Binding UseTransactionalExecution, Mode=TwoWay}"
                Content="Tx Mode"/>

        <Button Grid.Column="14"
                Classes="danger compact"
                Command="{Binding RequestExecutePendingChangesCommand}"
                Content="Execute Pending"/>

        <Button Grid.Column="15"
                Classes="secondary compact"
                Command="{Binding TogglePinCommand}"
                Content="{Binding TogglePinText}"/>

        <Button Grid.Column="16"
                Classes="danger compact"
                Command="{Binding CloseSessionCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
            <TextBlock Text="Close Session"/>
          </StackPanel>
        </Button>

        <Border Grid.Column="17"
                Classes="chip"
                Padding="8,2"
                IsVisible="{Binding HasExecutionSafetyStatusText}">
          <TextBlock Text="{Binding ExecutionSafetyStatusText}"
                     Foreground="{StaticResource StatusWarningBrush}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="280"/>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,8,0,0"
            Classes="surface-card"
            Padding="8"
            IsVisible="{Binding HasSessions}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Sessions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="result:SqlResultSession">
              <Border Classes="surface-card"
                      Padding="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Classes="secondary compact"
                          Command="{Binding DataContext.SelectSessionCommand, ElementName=Root}"
                          CommandParameter="{Binding .}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding SqlText}"
                                 MaxWidth="220"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="Pinned"
                                 IsVisible="{Binding IsPinned}"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                  </Button>
                  <Button Classes="danger compact"
                          Command="{Binding DataContext.CloseSessionTabCommand, ElementName=Root}"
                          CommandParameter="{Binding .}"
                          Content="x"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="0,8,0,0"
            Classes="surface-card"
            Padding="10"
            IsVisible="{Binding HasPendingPreviewPanel}">
      <StackPanel Spacing="6">
        <TextBlock Text="Pending ChangeSet Preview"
                   FontWeight="{StaticResource FontWeightStrong}"/>
        <TextBlock Text="Production-like connection detected: direct execution is blocked."
                   Foreground="{StaticResource StatusWarningBrush}"
                   IsVisible="{Binding IsProductionLikeConnectionContext}"/>
        <TextBlock Text="{Binding TransactionModeStatusText}"
                   Foreground="{StaticResource StatusWarningBrush}"
                   IsVisible="{Binding HasTransactionModeStatusText}"/>
        <TextBlock Text="{Binding PendingChangeSetSummaryText}"
                   TextWrapping="Wrap"/>
        <TextBlock Text="{Binding PendingDiffPreviewText}"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding GeneratedPendingSqlText}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="74"
                 FontFamily="{StaticResource MonoFont}"/>
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <Button Classes="secondary compact"
                  Command="{Binding ClearPendingChangesPreviewCommand}"
                  Content="Clear Preview"/>
          <Button Classes="secondary compact"
                  Command="{Binding CopyGeneratedPendingSqlCommand}"
                  Content="Copy SQL"/>
          <Button Classes="secondary compact"
                  Command="{Binding SendGeneratedPendingSqlToEditorCommand}"
                  Content="Send to Editor"/>
          <Button Classes="danger compact"
                  Command="{Binding RequestExecutePendingChangesCommand}"
                  Content="Execute Pending"/>
        </StackPanel>

        <Border Classes="surface-card"
                Padding="8"
                IsVisible="{Binding IsPendingExecutionConfirmationVisible}">
          <StackPanel Spacing="6">
            <TextBlock Text="Direct execution confirmation required."
                       FontWeight="{StaticResource FontWeightStrong}"/>
            <TextBlock Text="The generated UPDATE statements will be validated with mutation guard and then executed."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="danger compact"
                      Command="{Binding ConfirmExecutePendingChangesCommand}"
                      Content="{Binding ConfirmExecutePendingChangesText}"/>
              <Button Classes="secondary compact"
                      Command="{Binding ConfirmExecutePendingChangesRollbackCommand}"
                      Content="Confirm Rollback"
                      IsVisible="{Binding HasTransactionRollbackOption}"/>
              <Button Classes="secondary compact"
                      Command="{Binding CancelExecutePendingChangesCommand}"
                      Content="Cancel"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding PendingExecutionStatusText}"
                   IsVisible="{Binding HasPendingExecutionStatusText}"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondaryBrush}"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="3"
            Grid.ColumnSpan="2"
            Margin="0,8,0,8"
            Classes="surface-card"
            Padding="10">
      <Grid RowDefinitions="Auto,Auto"
            ColumnDefinitions="*,*,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            ColumnSpacing="12">
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="18"
                   Text="{Binding ResultBreadcrumbText}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   TextTrimming="CharacterEllipsis"/>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="{Binding ConnectionId, StringFormat='Connection: {0}'}"/>
        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding DatabaseName, StringFormat='Database: {0}'}"/>
        <TextBlock Grid.Row="1"
                   Grid.Column="2"
                   Text="{Binding ExecutedAtText, StringFormat='Executed At: {0}'}"/>
        <TextBox Grid.Row="1"
                 Grid.Column="3"
                 Width="220"
                 Watermark="Search all columns"
                 Text="{Binding SearchText}"/>
        <ComboBox Grid.Row="1"
                  Grid.Column="4"
                  Width="180"
                  ItemsSource="{Binding AvailableSortColumns}"
                  SelectedItem="{Binding SelectedSortColumn, Mode=TwoWay}"/>
        <Button Grid.Row="1"
                Grid.Column="5"
                Classes="secondary compact"
                Command="{Binding ToggleSortDirectionCommand}"
                Content="{Binding SortDirectionText}"/>
        <Button Grid.Row="1"
                Grid.Column="6"
                Classes="secondary compact"
                Command="{Binding AddSortCriterionCommand}"
                Content="Add sort"/>
        <Button Grid.Row="1"
                Grid.Column="7"
                Classes="secondary compact"
                Command="{Binding ClearSortCriteriaCommand}"
                Content="Clear sorts"/>
        <ComboBox Grid.Row="1"
                  Grid.Column="8"
                  Width="170"
                  ItemsSource="{Binding AvailableSortColumns}"
                  SelectedItem="{Binding SelectedGroupColumn, Mode=TwoWay}"/>
        <Button Grid.Row="1"
                Grid.Column="9"
                Classes="secondary compact"
                Command="{Binding AddGroupColumnCommand}"
                Content="Add group"/>
        <Button Grid.Row="1"
                Grid.Column="10"
                Classes="secondary compact"
                Command="{Binding ClearGroupColumnsCommand}"
                Content="Clear groups"/>
        <ComboBox Grid.Row="1"
                  Grid.Column="11"
                  Width="170"
                  ItemsSource="{Binding AvailableSortColumns}"
                  SelectedItem="{Binding SelectedFilterColumn, Mode=TwoWay}"/>
        <ComboBox Grid.Row="1"
                  Grid.Column="12"
                  Width="130"
                  ItemsSource="{Binding AvailableFilterOperations}"
                  SelectedItem="{Binding SelectedFilterOperation, Mode=TwoWay}"/>
        <TextBox Grid.Row="1"
                 Grid.Column="13"
                 Width="170"
                 Watermark="Column filter"
                 Text="{Binding ColumnFilterValue}"/>
        <StackPanel Grid.Row="1"
                    Grid.Column="14"
                    Orientation="Horizontal"
                    Spacing="6">
          <Button Classes="secondary compact"
                  Command="{Binding ApplyColumnFilterCommand}"
                  Content="Add filter"/>
          <Button Classes="secondary compact"
                  Command="{Binding ClearColumnFilterCommand}"
                  Content="Clear filters"/>
        </StackPanel>
        <TextBox Grid.Row="1"
                 Grid.Column="15"
                 Width="220"
                 Watermark="Session annotation"
                 Text="{Binding SessionAnnotationText, Mode=TwoWay}"/>
        <Button Grid.Row="1"
                Grid.Column="16"
                Classes="secondary compact"
                Command="{Binding SaveSessionAnnotationCommand}"
                Content="Save note"/>
        <Button Grid.Row="1"
                Grid.Column="17"
                Classes="secondary compact"
                Command="{Binding ClearSessionAnnotationCommand}"
                Content="Clear note"/>
      </Grid>
    </Border>

    <Border Grid.Row="4"
            Grid.Column="0"
            Margin="0,0,8,0"
            Classes="surface-card"
            Padding="8">
      <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0"
                   Text="Recent Sessions"
                   FontWeight="{StaticResource FontWeightStrong}"/>

        <ListBox Grid.Row="1"
                 Margin="0,8,0,0"
                 ItemsSource="{Binding Sessions}"
                 SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                 IsVisible="{Binding HasSessions}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="result:SqlResultSession">
              <Border Classes="surface-card"
                      Margin="0,0,0,6"
                      Padding="8">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Row="0"
                             Grid.Column="0"
                             Text="{Binding SqlText}"
                             TextTrimming="CharacterEllipsis"
                             TextWrapping="NoWrap"/>
                  <TextBlock Grid.Row="1"
                             Grid.Column="0"
                             Margin="0,4,0,0"
                             Text="{Binding ExecutedAt.LocalDateTime, StringFormat='dd/MM HH:mm:ss'}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <TextBlock Grid.Row="2"
                             Grid.Column="0"
                             Margin="0,4,0,0"
                             Text="{Binding Annotation, StringFormat='Note: {0}'}"
                             TextWrapping="Wrap"
                             IsVisible="{Binding Annotation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                  <Border Grid.Row="0"
                          Grid.Column="1"
                          Grid.RowSpan="3"
                          Classes="chip"
                          IsVisible="{Binding IsPinned}"
                          Padding="6,2">
                    <TextBlock Text="Pinned"/>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2"
              Margin="0,8,0,0"
              ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="Group Criteria"
                     FontWeight="{StaticResource FontWeightStrong}"/>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding ClearGroupColumnsCommand}"
                  Content="Clear"/>
        </Grid>

        <ItemsControl Grid.Row="3"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding ActiveGroupColumns}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,4"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding ColumnName}"/>
                <Button Grid.Column="1"
                        Classes="secondary compact"
                        Command="{Binding DataContext.RemoveGroupColumnCommand, ElementName=Root}"
                        CommandParameter="{Binding .}"
                        Content="x"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4"
              Margin="0,8,0,0"
              ColumnDefinitions="*,Auto"
              IsVisible="{Binding HasGroupBuckets}">
          <TextBlock Grid.Column="0"
                     Text="Group Buckets"
                     FontWeight="{StaticResource FontWeightStrong}"/>
        </Grid>

        <ItemsControl Grid.Row="5"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding GroupBuckets}"
                      IsVisible="{Binding HasGroupBuckets}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,4"
                    ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding GroupKey}"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding RowCount}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Grid.Column="2"
                        Classes="secondary compact"
                        Command="{Binding DataContext.ToggleGroupBucketCollapsedCommand, ElementName=Root}"
                        CommandParameter="{Binding .}"
                        Content="{Binding CollapseActionText}"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="6"
              Margin="0,8,0,0"
              ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="Sort Criteria"
                     FontWeight="{StaticResource FontWeightStrong}"/>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding ClearSortCriteriaCommand}"
                  Content="Clear"/>
        </Grid>

        <ItemsControl Grid.Row="7"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding ActiveSortCriteria}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,4"
                    ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding ColumnName}"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding DirectionText}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Grid.Column="2"
                        Classes="secondary compact"
                        Command="{Binding DataContext.RemoveSortCriterionCommand, ElementName=Root}"
                        CommandParameter="{Binding .}"
                        Content="x"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="8"
              Margin="0,8,0,0"
              ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="Filter Criteria"
                     FontWeight="{StaticResource FontWeightStrong}"/>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding ClearColumnFilterCommand}"
                  Content="Clear"/>
        </Grid>

        <ItemsControl Grid.Row="9"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding ActiveFilterCriteria}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,4"
                    ColumnDefinitions="*,Auto,Auto,Auto"
                    ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding ColumnName}"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding OperationText}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="{Binding Value}"/>
                <Button Grid.Column="3"
                        Classes="secondary compact"
                        Command="{Binding DataContext.RemoveColumnFilterCommand, ElementName=Root}"
                        CommandParameter="{Binding .}"
                        Content="x"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="10"
              Margin="0,8,0,0"
              ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="Visible Columns"
                     FontWeight="{StaticResource FontWeightStrong}"/>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding ShowAllColumnsCommand}"
                  Content="Show all"/>
        </Grid>

        <ScrollViewer Grid.Row="11"
                      Margin="0,8,0,0"
                      MaxHeight="520"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">
            <ItemsControl ItemsSource="{Binding ColumnVisibilityItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,4"
                        ColumnDefinitions="*,Auto,Auto,Auto"
                        ColumnSpacing="4">
                    <CheckBox Grid.Column="0"
                              Content="{Binding ColumnName}"
                              IsChecked="{Binding IsVisible, Mode=TwoWay}"/>
                    <Button Grid.Column="1"
                            Classes="secondary compact"
                            Command="{Binding DataContext.MoveColumnUpCommand, ElementName=Root}"
                            CommandParameter="{Binding .}"
                            Content="Up"/>
                    <Button Grid.Column="2"
                            Classes="secondary compact"
                            Command="{Binding DataContext.MoveColumnDownCommand, ElementName=Root}"
                            CommandParameter="{Binding .}"
                            Content="Down"/>
                    <Button Grid.Column="3"
                            Classes="secondary compact"
                            Command="{Binding DataContext.ToggleColumnFrozenCommand, ElementName=Root}"
                            CommandParameter="{Binding .}"
                            Content="{Binding FrozenActionText}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="surface-card" Padding="8">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                  <TextBlock Grid.Column="0"
                             Text="Snippets"
                             FontWeight="{StaticResource FontWeightStrong}"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding FavoriteSnippetCountText}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>

                <TextBox Watermark="Snippet name"
                         Text="{Binding SnippetNameInput, Mode=TwoWay}"/>
                <TextBox Watermark="Snippet description"
                         Text="{Binding SnippetDescriptionInput, Mode=TwoWay}"/>
                <TextBox Watermark="Tags"
                         Text="{Binding SnippetTagsInput, Mode=TwoWay}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <Button Grid.Column="0"
                          Classes="secondary compact"
                          Command="{Binding SaveCurrentSqlAsSnippetCommand}"
                          Content="Save Snippet"/>
                  <Button Grid.Column="1"
                          Classes="secondary compact"
                          Command="{Binding ToggleCurrentSqlFavoriteCommand}"
                          Content="{Binding ToggleCurrentSqlFavoriteText}"/>
                </Grid>

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <Button Grid.Column="0"
                          Classes="secondary compact"
                          Command="{Binding OpenSelectedSnippetInEditorCommand}"
                          Content="Open Selected"/>
                  <Button Grid.Column="1"
                          Classes="secondary compact"
                          Command="{Binding DeleteSelectedSnippetCommand}"
                          Content="Delete Selected"/>
                </Grid>

                <ListBox ItemsSource="{Binding SavedSnippets}"
                         SelectedItem="{Binding SelectedSnippet, Mode=TwoWay}"
                         MaxHeight="180">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="result:SqlSavedQuerySnippet">
                      <Border Classes="surface-card" Margin="0,0,0,6" Padding="6">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="6">
                          <TextBlock Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding Name}"
                                     FontWeight="{StaticResource FontWeightStrong}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Row="1"
                                     Grid.Column="0"
                                     Text="{Binding Description}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap"/>
                          <TextBlock Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding Tags}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Row="0"
                                     Grid.Column="1"
                                     Text="Fav"
                                     IsVisible="{Binding IsFavorite}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                          <Button Grid.Row="0"
                                  Grid.Column="2"
                                  Classes="secondary compact"
                                  Command="{Binding DataContext.OpenSnippetInEditorCommand, ElementName=Root}"
                                  CommandParameter="{Binding .}"
                                  Content="Open"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border Classes="surface-card" Padding="6">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Quick Templates"
                               FontWeight="{StaticResource FontWeightStrong}"/>
                    <ComboBox ItemsSource="{Binding AvailableSqlTemplates}"
                              SelectedItem="{Binding SelectedSqlTemplate, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding SelectedSqlTemplate.Description}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Classes="secondary compact"
                            Command="{Binding SendSelectedSqlTemplateToEditorCommand}"
                            Content="Send Template to Editor"/>
                  </StackPanel>
                </Border>

                <Border Classes="surface-card" Padding="6"
                        IsVisible="{Binding HasAvailableTableQuickActions}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Table Quick Actions"
                               FontWeight="{StaticResource FontWeightStrong}"/>
                    <ItemsControl ItemsSource="{Binding AvailableTableQuickActions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="surface-card" Margin="0,0,0,6" Padding="6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="6">
                              <TextBlock Grid.Row="0"
                                         Grid.Column="0"
                                         Text="{Binding Name}"
                                         FontWeight="{StaticResource FontWeightStrong}"/>
                              <TextBlock Grid.Row="1"
                                         Grid.Column="0"
                                         Text="{Binding Description}"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         TextWrapping="Wrap"/>
                              <Button Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Classes="secondary compact"
                                      Command="{Binding DataContext.SendTableQuickActionToEditorCommand, ElementName=Root}"
                                      CommandParameter="{Binding .}"
                                      Content="Send"/>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="4"
            Grid.Column="1"
            Classes="surface-card"
            Padding="8">
      <Grid RowDefinitions="*,Auto,Auto,Auto,Auto">
        <DataGrid Grid.Row="0"
                  x:Name="ResultGrid"
                  ItemsSource="{Binding RowsView}"
                  SelectedItem="{Binding SelectedRowItem, Mode=TwoWay}"
                  IsReadOnly="False"
                  GridLinesVisibility="Horizontal"
                  AutoGenerateColumns="False"
                  FrozenColumnCount="{Binding FrozenColumnCount}"
                  SelectionMode="Extended"
                  CellPointerPressed="ResultGrid_OnCellPointerPressed"
                  CellEditEnding="ResultGrid_OnCellEditEnding">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Copy Cell"
                        Command="{Binding CopySelectedCellCommand}"/>
              <MenuItem Header="Copy Row JSON"
                        Command="{Binding CopySelectedRowAsJsonCommand}"/>
              <MenuItem Header="Copy Row CSV"
                        Command="{Binding CopySelectedRowAsCsvCommand}"/>
              <MenuItem Header="Copy Row Markdown"
                        Command="{Binding CopySelectedRowAsMarkdownCommand}"/>
              <MenuItem Header="Show Row Details"
                        Command="{Binding ShowSelectedRowDetailsCommand}"/>
              <Separator/>
              <MenuItem Header="Copy Visible Rows JSON"
                        Command="{Binding CopyVisibleRowsAsJsonCommand}"/>
              <MenuItem Header="Copy Visible Rows CSV"
                        Command="{Binding CopyVisibleRowsAsCsvCommand}"/>
              <MenuItem Header="Copy Visible Rows Markdown"
                        Command="{Binding CopyVisibleRowsAsMarkdownCommand}"/>
              <Separator/>
              <MenuItem Header="Export Visible Rows CSV"
                        Command="{Binding ExportVisibleRowsAsCsvCommand}"/>
              <MenuItem Header="Export Visible Rows JSON"
                        Command="{Binding ExportVisibleRowsAsJsonCommand}"/>
              <MenuItem Header="Copy Column as SQL IN"
                        Command="{Binding CopySelectedColumnAsSqlInCommand}"/>
              <Separator/>
              <MenuItem Header="Filter by Cell Value"
                        Command="{Binding FilterBySelectedCellValueCommand}"/>
              <MenuItem Header="Sort Asc"
                        Command="{Binding SortSelectedColumnAscendingCommand}"/>
              <MenuItem Header="Sort Desc"
                        Command="{Binding SortSelectedColumnDescendingCommand}"/>
              <MenuItem Header="Hide Column"
                        Command="{Binding HideSelectedCellColumnCommand}"/>
              <Separator/>
              <MenuItem Header="Generate WHERE"
                        Command="{Binding GenerateWhereClauseCommand}"/>
              <MenuItem Header="Open Related Record (FK)"
                        Command="{Binding NavigateSelectedForeignKeyCommand}"/>
            </ContextMenu>
          </DataGrid.ContextMenu>
        </DataGrid>

        <Grid Grid.Row="1"
              Margin="0,8,0,0"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*"
              ColumnSpacing="8">
          <Button Grid.Column="0"
                  Classes="secondary compact"
                  Command="{Binding FirstPageCommand}"
                  Content="&lt;&lt;"/>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding PreviousPageCommand}"
                  Content="&lt;"/>
          <Button Grid.Column="2"
                  Classes="secondary compact"
                  Command="{Binding NextPageCommand}"
                  Content="&gt;"/>
          <Button Grid.Column="3"
                  Classes="secondary compact"
                  Command="{Binding LastPageCommand}"
                  Content="&gt;&gt;"/>
          <TextBlock Grid.Column="4"
                     VerticalAlignment="Center"
                     Text="{Binding PageSummaryText, StringFormat='Page {0}'}"/>
          <TextBlock Grid.Column="5"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Text="{Binding RowCountText, StringFormat='Filtered Rows: {0}'}"
                     Foreground="{StaticResource TextSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="2"
              Margin="0,8,0,0"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*"
              ColumnSpacing="8">
          <Border Grid.Column="0"
                  Classes="chip"
                  Padding="8,2">
            <TextBlock Text="{Binding SelectedCellSummary, StringFormat='Cell: {0}'}"/>
          </Border>
          <Button Grid.Column="1"
                  Classes="secondary compact"
                  Command="{Binding CopySelectedCellCommand}"
                  Content="Copy Cell"/>
          <Button Grid.Column="2"
                  Classes="secondary compact"
                  Command="{Binding CopySelectedRowAsJsonCommand}"
                  Content="Copy Row JSON"/>
          <Button Grid.Column="3"
                  Classes="secondary compact"
                  Command="{Binding CopySelectedRowAsCsvCommand}"
                  Content="Copy Row CSV"/>
          <Button Grid.Column="4"
                  Classes="secondary compact"
                  Command="{Binding CopySelectedRowAsMarkdownCommand}"
                  Content="Copy Row MD"/>
          <StackPanel Grid.Column="5"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Classes="secondary compact"
                    Command="{Binding CopyVisibleRowsAsJsonCommand}"
                    Content="Copy Page JSON"/>
            <Button Classes="secondary compact"
                    Command="{Binding CopyVisibleRowsAsCsvCommand}"
                    Content="Copy Page CSV"/>
            <Button Classes="secondary compact"
                    Command="{Binding CopyVisibleRowsAsMarkdownCommand}"
                    Content="Copy Page MD"/>
            <Button Classes="secondary compact"
                    Command="{Binding ExportVisibleRowsAsCsvCommand}"
                    Content="Export CSV"/>
            <Button Classes="secondary compact"
                    Command="{Binding ExportVisibleRowsAsJsonCommand}"
                    Content="Export JSON"/>
            <Button Classes="secondary compact"
                    Click="ExportReportButton_Click"
                    Content="Export Report"/>
            <Button Classes="secondary compact"
                    Command="{Binding CopySelectedColumnAsSqlInCommand}"
                    Content="Copy SQL IN"/>
            <Button Classes="secondary compact"
                    Command="{Binding GenerateWhereClauseCommand}"
                    Content="Generate WHERE"/>
            <Button Classes="secondary compact"
                    Command="{Binding NavigateSelectedForeignKeyCommand}"
                    Content="Open Related FK"/>
          </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Padding="8"
                Classes="surface-card"
                IsVisible="{Binding IsResultDetailVisible}">
          <Grid ColumnDefinitions="2*,3*"
                ColumnSpacing="10">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*">
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           Text="{Binding SelectedRowSummary, StringFormat='Selected {0}'}"
                           FontWeight="{StaticResource FontWeightStrong}"/>
                <Button Grid.Column="1"
                        Classes="secondary compact"
                        Command="{Binding HideSelectedRowDetailsCommand}"
                        Content="Close"/>
                <Button Grid.Column="2"
                        Classes="secondary compact"
                        Command="{Binding ClearSelectedRowCommand}"
                        Content="Clear"/>
              </Grid>

              <ItemsControl Grid.Row="1"
                            Margin="0,8,0,0"
                            ItemsSource="{Binding SelectedRowFields}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,4"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="6">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding ColumnName}"
                                 FontWeight="{StaticResource FontWeightStrong}"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Value}"
                                 TextWrapping="Wrap"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*">
              <TextBlock Grid.Row="0"
                         Text="Row JSON"
                         FontWeight="{StaticResource FontWeightStrong}"/>
              <TextBox Grid.Row="1"
                       Margin="0,8,0,0"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       Text="{Binding SelectedRowJson}"/>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,8,0,0"
                Padding="8"
                Classes="surface-card">
          <StackPanel Spacing="6">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="Column Profiles"
                         FontWeight="{StaticResource FontWeightStrong}"/>
              <Button Grid.Column="1"
                      Classes="secondary compact"
                      Command="{Binding BuildColumnProfilesCommand}"
                      Content="Analyze"/>
            </Grid>

            <TextBlock Text="{Binding ColumnProfileStatusText}"
                       IsVisible="{Binding HasColumnProfileStatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <TextBlock Text="{Binding DataQualitySummaryText}"
                       IsVisible="{Binding HasDataQualitySummaryText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <ScrollViewer MaxHeight="120"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding HasDataQualityIssues}">
              <ItemsControl ItemsSource="{Binding DataQualityIssues}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="surface-card"
                            Margin="0,0,0,6"
                            Padding="6">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Severity, StringFormat='[{0}]'}"
                                   FontWeight="{StaticResource FontWeightStrong}"/>
                        <TextBlock Text="{Binding ColumnName, StringFormat='Column: {0}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Message}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <ScrollViewer MaxHeight="180"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding HasColumnProfiles}">
              <ItemsControl ItemsSource="{Binding ColumnProfiles}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="surface-card"
                            Margin="0,0,0,6"
                            Padding="6">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{Binding ColumnName}"
                                   FontWeight="{StaticResource FontWeightStrong}"/>
                        <TextBlock Text="{Binding KindText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SummaryText}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TopValuesText, StringFormat='Top: {0}'}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <Border Classes="surface-card"
                    Padding="6"
                    Margin="0,6,0,0">
              <StackPanel Spacing="6">
                <TextBlock Text="Result Comparison"
                           FontWeight="{StaticResource FontWeightStrong}"/>
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="6">
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding ComparableSessions}"
                            SelectedItem="{Binding SelectedComparisonSession, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}"
                                   TextTrimming="CharacterEllipsis"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Grid.Column="1"
                          Classes="secondary compact"
                          Command="{Binding CompareWithSelectedSessionCommand}"
                          Content="Compare"/>
                  <Button Grid.Column="2"
                          Classes="secondary compact"
                          Command="{Binding ClearComparisonCommand}"
                          Content="Clear"/>
                </Grid>

                <TextBlock Text="{Binding ComparisonSummaryText}"
                           IsVisible="{Binding HasComparisonSummaryText}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <ScrollViewer MaxHeight="140"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasComparisonDiffItems}">
                  <ItemsControl ItemsSource="{Binding ComparisonDiffItems}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="surface-card"
                                Margin="0,0,0,6"
                                Padding="6">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding ChangeType, StringFormat='[{0}]'}"
                                       FontWeight="{StaticResource FontWeightStrong}"/>
                            <TextBlock Text="{Binding RowKey}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Detail}"
                                       TextWrapping="Wrap"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
