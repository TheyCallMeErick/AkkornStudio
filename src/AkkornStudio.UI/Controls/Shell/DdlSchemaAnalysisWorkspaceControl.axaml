<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AkkornStudio.UI.ViewModels"
             xmlns:loc="using:AkkornStudio.UI.Services.Localization"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Name="Root"
             x:Class="AkkornStudio.UI.Controls.Shell.DdlSchemaAnalysisWorkspaceControl"
             KeyDown="OnHostKeyDown"
             x:DataType="vm:DdlSchemaAnalysisWorkspaceViewModel">
  <UserControl.Styles>
    <Style Selector="Border.playground-config-card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2A313C"/>
      <Setter Property="Background" Value="#151A22"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="Border.playground-config-card.playground-highlight">
      <Setter Property="BorderBrush" Value="#3A7AD8"/>
      <Setter Property="Background" Value="#182334"/>
    </Style>

    <Style Selector="Border.playground-preview-card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2B3342"/>
      <Setter Property="Background" Value="#131824"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="Border.playground-preview-card.playground-highlight">
      <Setter Property="BorderBrush" Value="#4D87E4"/>
      <Setter Property="Background" Value="#17263A"/>
    </Style>

    <Style Selector="Border.playground-line.playground-highlight">
      <Setter Property="Background" Value="#1D2533"/>
    </Style>

    <Style Selector="Border.playground-badge">
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Background" Value="#2B303A"/>
      <Setter Property="BorderBrush" Value="#3C4352"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.playground-badge.pk">
      <Setter Property="Background" Value="#3A2B1A"/>
      <Setter Property="BorderBrush" Value="#A7792E"/>
    </Style>
    <Style Selector="Border.playground-badge.fk">
      <Setter Property="Background" Value="#162A46"/>
      <Setter Property="BorderBrush" Value="#4F87D8"/>
    </Style>
    <Style Selector="Border.playground-badge.idx">
      <Setter Property="Background" Value="#2A1B43"/>
      <Setter Property="BorderBrush" Value="#8A5ED3"/>
    </Style>
    <Style Selector="Border.playground-badge.view">
      <Setter Property="Background" Value="#14313D"/>
      <Setter Property="BorderBrush" Value="#49BFD6"/>
    </Style>
    <Style Selector="Border.playground-badge.unique">
      <Setter Property="Background" Value="#203327"/>
      <Setter Property="BorderBrush" Value="#5CA874"/>
    </Style>
    <Style Selector="Border.playground-badge.check">
      <Setter Property="Background" Value="#3A2D15"/>
      <Setter Property="BorderBrush" Value="#B68D38"/>
    </Style>
    <Style Selector="Border.playground-badge.constraint">
      <Setter Property="Background" Value="#2B2438"/>
      <Setter Property="BorderBrush" Value="#76659A"/>
    </Style>

    <Style Selector="Border.playground-validation-item">
      <Setter Property="Background" Value="#15202A"/>
      <Setter Property="BorderBrush" Value="#2D3A4B"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="8"/>
    </Style>
    <Style Selector="Border.playground-validation-item.validation-invalid">
      <Setter Property="BorderBrush" Value="#B45C64"/>
      <Setter Property="Background" Value="#2A1C22"/>
    </Style>
    <Style Selector="Border.playground-validation-item.playground-highlight">
      <Setter Property="BorderBrush" Value="#4F87D8"/>
    </Style>

    <Style Selector="Border.playground-issue-item">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Background" Value="#151B25"/>
      <Setter Property="BorderBrush" Value="#2D3645"/>
    </Style>
    <Style Selector="Border.playground-issue-item.issue-success">
      <Setter Property="Background" Value="#182921"/>
      <Setter Property="BorderBrush" Value="#3D7F58"/>
    </Style>
    <Style Selector="Border.playground-issue-item.issue-warning">
      <Setter Property="Background" Value="#2B2418"/>
      <Setter Property="BorderBrush" Value="#9D7A3C"/>
    </Style>
    <Style Selector="Border.playground-issue-item.issue-error">
      <Setter Property="Background" Value="#2D1E23"/>
      <Setter Property="BorderBrush" Value="#B7616C"/>
    </Style>
    <Style Selector="Border.playground-issue-item.playground-highlight">
      <Setter Property="BorderBrush" Value="#4F87D8"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="8">
    <Border Grid.Row="0" Classes="surface-panel" Padding="12" Margin="0,0,0,8">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
          <mi:MaterialIcon Grid.Column="0" Kind="Radar" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource StatusInfoBrush}"/>
          <StackPanel Grid.Column="1" Spacing="2">
            <TextBlock Text="Diagnostico de estrutura" FontWeight="{StaticResource FontWeightTitle}"/>
            <TextBlock Text="{Binding StatusMessage}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
            <Button Command="{Binding PreviousStepCommand}" Classes="secondary compact" Content="Voltar"/>
            <Button Command="{Binding NextStepCommand}" Classes="secondary compact" Content="Proximo"/>
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
          <Border Grid.Column="0" Classes="surface-card" Padding="8" Background="{StaticResource PanelActiveBrush}" IsVisible="{Binding IsConnectionStepCurrent}">
            <TextBlock Text="1. Conexao" FontWeight="{StaticResource FontWeightStrong}"/>
          </Border>
          <Border Grid.Column="0" Classes="surface-card" Padding="8" IsVisible="{Binding IsConnectionStepCompleted}">
            <Button Command="{Binding OpenConnectionStepCommand}" Classes="secondary compact" Content="1. Conexao"/>
          </Border>

          <Border Grid.Column="1" Classes="surface-card" Padding="8" Background="{StaticResource PanelActiveBrush}" IsVisible="{Binding IsTrendsStepCurrent}">
            <TextBlock Text="2. Tendencias" FontWeight="{StaticResource FontWeightStrong}"/>
          </Border>
          <Border Grid.Column="1" Classes="surface-card" Padding="8" IsVisible="{Binding IsTrendsStepCompleted}">
            <Button Command="{Binding OpenTrendsStepCommand}" Classes="secondary compact" Content="2. Tendencias"/>
          </Border>

          <Border Grid.Column="2" Classes="surface-card" Padding="8" Background="{StaticResource PanelActiveBrush}" IsVisible="{Binding IsDesiredNamingStepCurrent}">
            <TextBlock Text="3. Padroes" FontWeight="{StaticResource FontWeightStrong}"/>
          </Border>
          <Border Grid.Column="2" Classes="surface-card" Padding="8" IsVisible="{Binding IsDesiredNamingStepCompleted}">
            <Button Command="{Binding OpenDesiredNamingStepCommand}" Classes="secondary compact" Content="3. Padroes"/>
          </Border>

          <Border Grid.Column="3" Classes="surface-card" Padding="8" Background="{StaticResource PanelActiveBrush}" IsVisible="{Binding IsIssuesStepCurrent}">
            <TextBlock Text="4. Issues" FontWeight="{StaticResource FontWeightStrong}"/>
          </Border>
          <Border Grid.Column="3" Classes="surface-card" Padding="8" IsVisible="{Binding IsIssuesStepCompleted}">
            <Button Command="{Binding OpenIssuesStepCommand}" Classes="secondary compact" Content="4. Issues"/>
          </Border>
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Classes="surface-panel" Padding="10">
      <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsConnectionStep}">
          <StackPanel Spacing="10">
            <Border Classes="surface-card" Padding="10">
              <StackPanel Spacing="8">
                <TextBlock Text="Conexao alvo" FontWeight="{StaticResource FontWeightStrong}"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding Profiles}"
                            SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                            DisplayMemberBinding="{Binding Name}"
                           />
                  <Button Grid.Column="1" Command="{Binding OpenConnectionManagerCommand}" Classes="secondary compact" Content="Gerenciar"/>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <ComboBox Grid.Column="0" ItemsSource="{Binding Databases}" SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}"/>
                  <ComboBox Grid.Column="1" ItemsSource="{Binding Schemas}" SelectedItem="{Binding SelectedSchema, Mode=TwoWay}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Command="{Binding RefreshMetadataCommand}" Classes="secondary compact" Content="Atualizar metadata"/>
                  <Button Command="{Binding NextStepCommand}" Classes="secondary compact" Content="Continuar"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsTrendsStep}">
          <StackPanel Spacing="10">
            <TextBlock Text="Estado atual (sem issues)" FontWeight="{StaticResource FontWeightTitle}"/>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="Tabelas" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding TotalTables}" FontWeight="{StaticResource FontWeightTitle}"/>
                </StackPanel>
              </Border>
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="Colunas" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding TotalColumns}" FontWeight="{StaticResource FontWeightTitle}"/>
                </StackPanel>
              </Border>
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="FKs" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding TotalForeignKeys}" FontWeight="{StaticResource FontWeightTitle}"/>
                </StackPanel>
              </Border>
            </Grid>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="Naming dominante" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding DominantNaming}" FontWeight="{StaticResource FontWeightStrong}"/>
                </StackPanel>
              </Border>
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="Padrao PK dominante" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding DominantPkPattern}" FontWeight="{StaticResource FontWeightStrong}"/>
                </StackPanel>
              </Border>
              <Border Classes="surface-card" Padding="10">
                <StackPanel>
                  <TextBlock Text="Padrao FK dominante" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                  <TextBlock Text="{Binding DominantFkPattern}" FontWeight="{StaticResource FontWeightStrong}"/>
                </StackPanel>
              </Border>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Command="{Binding PreviousStepCommand}" Classes="secondary compact" Content="Voltar"/>
              <Button Command="{Binding NextStepCommand}" Classes="secondary compact" Content="Definir padroes"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsDesiredNamingStep}">
          <StackPanel Spacing="10">
            <Border Classes="surface-card" Padding="12">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Button Grid.Column="0" Command="{Binding PreviousStepCommand}" Classes="secondary compact" Content="Voltar"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="Naming Standards Playground" FontWeight="{StaticResource FontWeightTitle}" FontSize="{StaticResource FontSizeDisplay}"/>
                  <TextBlock Text="Configure e valide padroes de nomenclatura com preview reativo do modelo de dados." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding GenerateIssuesCommand}" Classes="secondary compact" Content="Gerar issues de padronizacao"/>
              </Grid>
            </Border>

            <Grid ColumnDefinitions="1.15*,1*" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="10">
                <Border Classes="playground-config-card" Padding="12"
                        Tag="tables"
                        PointerEntered="PlaygroundScope_OnPointerEntered"
                        PointerExited="PlaygroundScope_OnPointerExited">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Tabelas e colunas" FontWeight="{StaticResource FontWeightTitle}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de tabela" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding TableNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding TableNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de coluna" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding ColumnNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ColumnNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Padrao da coluna PK" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Text="{Binding PrimaryKeyPattern, Mode=TwoWay}" Watermark="id"/>
                        <TextBlock Text="{Binding PrimaryKeyTemplateExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Spacing="4">
                        <TextBlock Text="Template da constraint PK" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Text="{Binding PrimaryKeyConstraintPattern, Mode=TwoWay}" Watermark="pk_[table]"/>
                        <TextBlock Text="{Binding PrimaryKeyConstraintTemplateExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="playground-config-card" Padding="12"
                        Tag="indexes"
                        PointerEntered="PlaygroundScope_OnPointerEntered"
                        PointerExited="PlaygroundScope_OnPointerExited">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Indices" FontWeight="{StaticResource FontWeightTitle}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de indice" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding IndexNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding IndexNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Spacing="4">
                        <TextBlock Text="Template de indice" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Text="{Binding IndexPattern, Mode=TwoWay}" Watermark="idx_[table]_[column]"/>
                        <TextBlock Text="{Binding IndexTemplateExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="playground-config-card" Padding="12"
                        Tag="constraints"
                        PointerEntered="PlaygroundScope_OnPointerEntered"
                        PointerExited="PlaygroundScope_OnPointerExited">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Constraints" FontWeight="{StaticResource FontWeightTitle}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de constraint" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding ConstraintNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ConstraintNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Spacing="4">
                        <TextBlock Text="Template da coluna FK" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Text="{Binding ForeignKeyPattern, Mode=TwoWay}" Watermark="[target]_id"/>
                        <TextBlock Text="{Binding ForeignKeyTemplateExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                    <StackPanel Spacing="4">
                      <TextBlock Text="Template da constraint FK" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBox Text="{Binding ConstraintPattern, Mode=TwoWay}" Watermark="fk_[table]_[target]"/>
                      <TextBlock Text="{Binding ConstraintTemplateExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <Border Classes="playground-config-card" Padding="12"
                        Tag="views"
                        PointerEntered="PlaygroundScope_OnPointerEntered"
                        PointerExited="PlaygroundScope_OnPointerExited">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Views" FontWeight="{StaticResource FontWeightTitle}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de view" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding ViewNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ViewNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                      <StackPanel Spacing="4">
                        <TextBlock Text="Naming de colunas em view" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox ItemsSource="{Binding NamingConventionOptions}" SelectedItem="{Binding ViewColumnNamingConvention, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ViewColumnNamingExample, StringFormat=Ex.: {0}}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="playground-config-card" Padding="12"
                        Tag="templates"
                        PointerEntered="PlaygroundScope_OnPointerEntered"
                        PointerExited="PlaygroundScope_OnPointerExited">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Templates de nomes" FontWeight="{StaticResource FontWeightTitle}"/>
                    <TextBlock Text="{Binding PlaygroundValidationSummary}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding TemplateValidationItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NamingPlaygroundValidationItemViewModel">
                          <Border Classes="playground-validation-item"
                                  Classes.validation-invalid="{Binding IsInvalid}"
                                  Classes.playground-highlight="{Binding IsHighlighted}"
                                  Margin="0,0,0,6"
                                  Tag="{Binding FocusKey}"
                                  PointerEntered="PlaygroundScope_OnPointerEntered"
                                  PointerExited="PlaygroundScope_OnPointerExited">
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}" FontWeight="{StaticResource FontWeightStrong}"/>
                              <TextBlock Text="{Binding RuleText}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding Message}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="1" Spacing="10">
                <Border Classes="surface-card" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Preview do padrao" FontWeight="{StaticResource FontWeightTitle}"/>
                    <TextBlock Text="Modelo de exemplo com customer, order, order_item e vw_customer_orders." FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ItemsControl ItemsSource="{Binding PlaygroundPreviewEntities}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NamingPlaygroundEntityCardViewModel">
                          <Border Classes="playground-preview-card"
                                  Classes.playground-highlight="{Binding IsHighlighted}"
                                  Margin="0,0,0,8"
                                  Padding="10"
                                  Tag="{Binding FocusKey}"
                                  PointerEntered="PlaygroundScope_OnPointerEntered"
                                  PointerExited="PlaygroundScope_OnPointerExited">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="{Binding EntityName}" FontWeight="{StaticResource FontWeightStrong}" TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1" Classes="playground-badge" Classes.view="{Binding IsViewKind}">
                                  <TextBlock Text="{Binding EntityKind}" FontSize="{StaticResource FontSizeCaption}"/>
                                </Border>
                              </Grid>
                              <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:NamingPlaygroundLineViewModel">
                                    <Border Classes="playground-line"
                                            Classes.playground-highlight="{Binding IsHighlighted}"
                                            CornerRadius="6"
                                            Padding="6"
                                            Tag="{Binding FocusKey}"
                                            PointerEntered="PlaygroundScope_OnPointerEntered"
                                            PointerExited="PlaygroundScope_OnPointerExited"
                                            Margin="0,0,0,4">
                                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Badges}">
                                          <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                              <StackPanel Orientation="Horizontal" Spacing="4"/>
                                            </ItemsPanelTemplate>
                                          </ItemsControl.ItemsPanel>
                                          <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:NamingPlaygroundBadgeViewModel">
                                              <Border Classes="playground-badge"
                                                      Classes.pk="{Binding IsPk}"
                                                      Classes.fk="{Binding IsFk}"
                                                      Classes.idx="{Binding IsIdx}"
                                                      Classes.view="{Binding IsView}"
                                                      Classes.unique="{Binding IsUnique}"
                                                      Classes.check="{Binding IsCheck}"
                                                      Classes.constraint="{Binding IsConstraint}">
                                                <TextBlock Text="{Binding Text}" FontSize="{StaticResource FontSizeCaption}"/>
                                              </Border>
                                            </DataTemplate>
                                          </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Classes="surface-card" Padding="12">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="Previa de issues e validacao" FontWeight="{StaticResource FontWeightTitle}"/>
                      <Button Grid.Column="1" Command="{Binding GenerateIssuesCommand}" Classes="secondary compact" Content="Analisar padroes do projeto"/>
                    </Grid>
                    <TextBlock IsVisible="{Binding HasNoPlaygroundIssuePreviewItems}" Text="{Binding PlaygroundIssueEmptyMessage}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ItemsControl ItemsSource="{Binding PlaygroundIssuePreviewItems}" IsVisible="{Binding HasPlaygroundIssuePreviewItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NamingPlaygroundIssueItemViewModel">
                          <Border Classes="playground-issue-item"
                                  Classes.issue-success="{Binding IsSuccess}"
                                  Classes.issue-warning="{Binding IsWarning}"
                                  Classes.issue-error="{Binding IsError}"
                                  Classes.playground-highlight="{Binding IsHighlighted}"
                                  Margin="0,0,0,8"
                                  Tag="{Binding FocusKey}"
                                  PointerEntered="PlaygroundScope_OnPointerEntered"
                                  PointerExited="PlaygroundScope_OnPointerExited">
                            <StackPanel Spacing="4">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="{Binding ObjectType}" FontWeight="{StaticResource FontWeightStrong}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SeverityLabel}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                              </Grid>
                              <TextBlock Text="{Binding CurrentName, StringFormat=Atual: {0}}" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding ExpectedName, StringFormat=Esperado: {0}}" TextWrapping="Wrap"/>
                              <TextBlock Text="{Binding Suggestion}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <Grid IsVisible="{Binding IsIssuesStep}" ColumnDefinitions="320,*" ColumnSpacing="8">
          <Border Grid.Column="0" Classes="surface-panel" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="8">
                <Border Classes="surface-card" Padding="10">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Resumo" FontWeight="{StaticResource FontWeightStrong}"/>
                    <TextBlock Text="{Binding SchemaAnalysisPanel.FilteredTotalIssues, StringFormat=Issues: {0}}"/>
                    <TextBlock Text="{Binding SchemaAnalysisPanel.FilteredCriticalCount, StringFormat=Criticas: {0}}"/>
                    <TextBlock Text="{Binding SchemaAnalysisPanel.FilteredWarningCount, StringFormat=Warnings: {0}}"/>
                    <TextBlock Text="{Binding SchemaAnalysisPanel.FilteredInfoCount, StringFormat=Info: {0}}"/>
                    <TextBlock Text="{Binding SchemaAnalysisPanel.OverallScore, StringFormat=Score: {0:F1}}"/>
                  </StackPanel>
                </Border>

                <Expander Classes="app-accordion" IsExpanded="True">
                  <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <mi:MaterialIcon Kind="FilterVariant" Width="14" Height="14" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBlock Text="Filtros"/>
                    </StackPanel>
                  </Expander.Header>
                  <StackPanel Margin="0,8,0,0" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <Button Grid.Column="0" Command="{Binding SchemaAnalysisPanel.ClearFiltersCommand}" Classes="secondary compact" Content="Limpar"/>
                      <ToggleButton Grid.Column="1" Margin="6,0,0,0" Classes="secondary" Content="Quick Wins" IsChecked="{Binding SchemaAnalysisPanel.QuickWinsOnly, Mode=TwoWay}"/>
                    </Grid>
                    <WrapPanel Orientation="Horizontal" ItemHeight="28" ItemWidth="96">
                      <CheckBox Content="Info" IsChecked="{Binding SchemaAnalysisPanel.IncludeInfo, Mode=TwoWay}"/>
                      <CheckBox Content="Warning" IsChecked="{Binding SchemaAnalysisPanel.IncludeWarning, Mode=TwoWay}"/>
                      <CheckBox Content="Critical" IsChecked="{Binding SchemaAnalysisPanel.IncludeCritical, Mode=TwoWay}"/>
                    </WrapPanel>
                    <TextBox Watermark="Filtro por tabela" Text="{Binding SchemaAnalysisPanel.TableTextFilter, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,Auto">
                      <Slider Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding SchemaAnalysisPanel.MinConfidenceFilter, Mode=TwoWay}"/>
                      <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding SchemaAnalysisPanel.MinConfidenceFilter, StringFormat={}{0:F2}}" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                    </Grid>
                  </StackPanel>
                </Expander>

                <Expander Classes="app-accordion" IsExpanded="False">
                  <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <mi:MaterialIcon Kind="EyeOffOutline" Width="14" Height="14" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBlock Text="Ignorar"/>
                    </StackPanel>
                  </Expander.Header>
                  <StackPanel Margin="0,8,0,0" Spacing="8">
                    <CheckBox Content="Ignorar views" IsChecked="{Binding SchemaAnalysisPanel.IgnoreViews, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBox Grid.Column="0" Name="IgnoredTableInput" KeyDown="IgnoredTableInput_OnKeyDown" Watermark="{Binding SchemaAnalysisPanel.IgnoredTableInputPlaceholder}" Text="{Binding SchemaAnalysisPanel.IgnoredTableInput, Mode=TwoWay}"/>
                      <Button Grid.Column="1" Margin="6,0,0,0" Command="{Binding SchemaAnalysisPanel.AddIgnoredTableCommand}" Classes="secondary compact" Content="Adicionar"/>
                    </Grid>
                    <ListBox Name="IgnoredTablesList" MaxHeight="140" ItemsSource="{Binding SchemaAnalysisPanel.IgnoredTables}" SelectedItem="{Binding SchemaAnalysisPanel.SelectedIgnoredTable, Mode=TwoWay}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Button Command="{Binding SchemaAnalysisPanel.RemoveSelectedIgnoredTableCommand}" Classes="secondary compact" Content="Remover"/>
                      <Button Command="{Binding SchemaAnalysisPanel.ClearIgnoredTablesCommand}" Classes="secondary compact" Content="Limpar"/>
                    </StackPanel>
                  </StackPanel>
                </Expander>
              </StackPanel>
            </ScrollViewer>
          </Border>

          <Grid Grid.Column="1" ColumnDefinitions="1.2*,1*" ColumnSpacing="8">
            <Border Grid.Column="0" Classes="surface-panel" Padding="10">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SchemaAnalysisPanel.GroupedIssues}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Expander Classes="app-accordion" IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Title}" FontWeight="{StaticResource FontWeightTitle}"/>
                            <TextBlock Text="{Binding Count}" Foreground="{StaticResource TextMutedBrush}"/>
                          </StackPanel>
                        </Expander.Header>
                        <ListBox ItemsSource="{Binding Items}" SelectionChanged="IssueListBox_OnSelectionChanged">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <StackPanel Margin="0,3" Spacing="2">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}">
                                  <Run Text="{Binding RuleCode}"/>
                                  <Run Text=" • "/>
                                  <Run Text="{Binding Confidence, StringFormat={}{0:P0}}"/>
                                </TextBlock>
                              </StackPanel>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </Expander>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Classes="surface-panel" Padding="10">
              <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,*">
                <Border Grid.Row="0" Classes="surface-section-title">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="TextBoxSearchOutline" Width="14" Height="14" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="Detalhes" FontWeight="{StaticResource FontWeightTitle}"/>
                  </StackPanel>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,8,0,8">
                  <Border Grid.Column="0" Classes="surface-card" Margin="0,0,6,0" Padding="10">
                    <StackPanel>
                      <TextBlock Text="Path" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBlock Text="{Binding SchemaAnalysisPanel.SelectedIssuePath}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Classes="surface-card" Padding="10">
                    <StackPanel>
                      <TextBlock Text="Confidence" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}"/>
                      <TextBlock Text="{Binding SchemaAnalysisPanel.SelectedIssueConfidencePercent}"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <TextBlock Grid.Row="2" Text="{Binding SchemaAnalysisPanel.DetailsMessage}" TextWrapping="Wrap"/>

                <ListBox Grid.Row="3" ItemsSource="{Binding SchemaAnalysisPanel.SelectedIssueEvidence}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock FontSize="{StaticResource FontSizeCaption}" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding Key}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding Value}"/>
                      </TextBlock>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="6" Margin="0,8,0,8">
                  <Button Command="{Binding SchemaAnalysisPanel.SelectPreviousIssueCommand}" Classes="secondary compact" Content="?"/>
                  <Button Command="{Binding SchemaAnalysisPanel.SelectNextIssueCommand}" Classes="secondary compact" Content="?"/>
                  <Button Command="{Binding SchemaAnalysisPanel.CopySqlCommand}" Click="CopySqlButton_OnClick" ToolTip.Tip="{Binding SchemaAnalysisPanel.ActionBlockedTooltip}" Classes="secondary compact" Content="Copiar SQL"/>
                  <Button Command="{Binding OpenInDdlCommand}" Classes="secondary compact" Content="Abrir no DDL"/>
                  <Button Command="{Binding RunAnalysisCommand}" Classes="secondary compact" Content="Reanalisar"/>
                </StackPanel>

                <ListBox Grid.Row="5" ItemsSource="{Binding SchemaAnalysisPanel.VisibleCandidates}" SelectedItem="{Binding SchemaAnalysisPanel.SelectedSqlCandidate, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Spacing="2" Margin="0,4">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource TextMutedBrush}">
                          <Run Text="{Binding Safety}"/>
                          <Run Text=" | "/>
                          <Run Text="{Binding Visibility}"/>
                        </TextBlock>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>



